{
  "name": "project",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "postbuild:locales": "mkdir -p dist/locales/fr dist/locales/en dist/locales/de dist/locales/es dist/locales/it && cp public/locales/fr/translation.json dist/locales/fr/translation.json && cp public/locales/en/translation.json dist/locales/en/translation.json && cp public/locales/de/translation.json dist/locales/de/translation.json && cp public/locales/es/translation.json dist/locales/es/translation.json && cp public/locales/it/translation.json dist/locales/it/translation.json",
    "mcp:n8n": "supergateway --config ./mcp_config.json --server n8n-mcp",
    "dev:mcp": "supergateway --config ./mcp_config.json --server n8n-mcp & npm run dev",
    "dev": "vite --host",
    "start": "netlify dev",
    "check-imports": "node check-imports.js",
    "verify-deps": "node verify-deps.js",
    "update-deps": "node update-deps.js",
    "netlify-prebuild": "node netlify-prebuild.js",
    "fix-supabase": "node fix-supabase.js",
    "cleanup-functions": "node cleanup-functions.js",
    "patch-vite-config": "node vite.config.patch.js",
    "build": "node verify-deps.js && node check-imports.js && npx tsc --outDir dist && vite build --config vite.config.mts && node clean-build.js",
    "build:analyze": "ANALYZE=true npm run build",
    "build:clean": "rimraf dist && node verify-deps.js && node check-imports.js && tsc && vite build --config vite.config.mts && node clean-build.js",
    "fix-imports": "node fix-component-imports.js",
    "fix-router-imports": "node fix-router-imports.js",
    "build:netlify": "rimraf dist && vite build --config vite.config.mts && npx tsx scripts/postbuild-locales.ts && echo 'Contenu du dossier dist après le build:' && ls -R dist && npx netlify functions:build --src netlify/functions",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "listfiles": "find . -not -path \"*/node_modules/*\" -not -path \"*/.git/*\" -not -path \"*/dist/*\"",
    "check-translations": "node scripts/check-translations.mjs",
    "test": "jest",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report e2e-results",
    "test:all": "npm run test:unit && npm run test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },

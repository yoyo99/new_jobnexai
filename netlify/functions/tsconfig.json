{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "noEmit": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["@netlify/functions", "@types/node"],
    "lib": ["ES2022"]
  },
  "include": [
    "./**/*.ts"
  ],
  "exclude": [
    "./dist/**/*",
    "./node_modules/**/*"
  ]
}

{
  "extends": [
    "@typescript-eslint/recommended",
    "plugin:@netlify/netlify/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "project": "./netlify/functions/tsconfig.json"
  },
  "plugins": [
    "@typescript-eslint",
    "@netlify"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "@typescript-eslint/explicit-function-return-type": "warn",
    "@typescript-eslint/no-explicit-any": "warn",
    "@netlify/netlify/no-node-globals": "error",
    "@netlify/netlify/no-exposed-secrets": "error",
    "prefer-const": "error",
    "no-var": "error"
  },
  "env": {
    "node": true,
    "es2022": true
  },
  "ignorePatterns": [
    "dist/",
    "node_modules/"
  ]
}

# Variables d'environnement pour JobNexAI

# 🔥 SUPABASE (OBLIGATOIRE pour Panel Admin)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key_supabase

# 🔑 SUPABASE SERVICE KEY (pour opérations admin)
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# 💳 STRIPE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxx
STRIPE_SECRET_KEY=sk_test_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# 🤖 OPENAI
OPENAI_API_KEY=sk-xxxx

# 📊 ANALYTICS
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ⚡ REDIS (cache documents)
REDIS_URL=redis://localhost:6379
REDIS_POLE_EMPLOI_TTL_SECONDS=604800

# ☁️ AWS S3 (stockage documents générés)
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-west-3
S3_BUCKET_POLE_EMPLOI=jobnexai-pole-emploi-docs
S3_SIGNED_URL_EXPIRY_SECONDS=3600

# 🇫🇷 API FRANCE TRAVAIL
FRANCE_TRAVAIL_CLIENT_ID=your_client_id
FRANCE_TRAVAIL_CLIENT_SECRET=your_client_secret
FRANCE_TRAVAIL_BASE_URL=https://api.francetravail.io
FRANCE_TRAVAIL_TOKEN_URL=https://entreprise.francetravail.fr/connexion/oauth2/access_token
FRANCE_TRAVAIL_SCOPE=api_offresdemploiv2
FRANCE_TRAVAIL_RATE_LIMIT_PER_MINUTE=30

# 📧 EMAIL SERVICE
RESEND_API_KEY=re_xxxx

# Firebase (legacy)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here

# EmailJS (legacy)
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# 🤖 N8N WORKFLOWS
VITE_N8N_URL=https://n8n.jobnexai.com
# Pour tests locaux : http://localhost:5678

# 🔐 Frontend webhook (temps réel)
VITE_N8N_WEBHOOK_URL=https://n8n.jobnexai.com/webhook/jobnexai
VITE_N8N_WEBHOOK_KEY=change_me_in_production
VITE_N8N_TIMEOUT_MS=120000

# 🛡️ Netlify Function proxy vers n8n
N8N_WEBHOOK_URL=https://n8n.jobnexai.com/webhook/jobnexai
N8N_API_KEY=change_me_in_production
N8N_JOB_SEARCH_TIMEOUT_MS=120000

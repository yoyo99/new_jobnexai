{
  "dashboard": {
    "title": "JobNexAI - N8N Workflows",
    "tags": ["jobnexai", "n8n", "workflows"],
    "timezone": "Europe/Paris",
    "schemaVersion": 36,
    "version": 1,
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "title": "Workflow Executions (Success vs Failed)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(n8n_workflow_executions_success_total[5m])",
            "legendFormat": "Success",
            "refId": "A"
          },
          {
            "expr": "rate(n8n_workflow_executions_failed_total[5m])",
            "legendFormat": "Failed",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Executions/sec"}
        ]
      },
      {
        "id": 2,
        "title": "Success Rate",
        "type": "gauge",
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "(rate(n8n_workflow_executions_success_total[5m]) / (rate(n8n_workflow_executions_success_total[5m]) + rate(n8n_workflow_executions_failed_total[5m]))) * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "max": 100,
            "min": 0,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 80},
                {"color": "green", "value": 95}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Active Workflows",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "n8n_active_workflows_total",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "yellow", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Queue Size",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 4},
        "targets": [
          {
            "expr": "n8n_queue_size",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 10},
                {"color": "red", "value": 50}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Execution Duration (p95)",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(n8n_workflow_execution_duration_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(n8n_workflow_execution_duration_seconds_bucket[5m]))",
            "legendFormat": "p50 (median)",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Duration"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [300], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "name": "Slow Workflow Executions"
        }
      },
      {
        "id": 6,
        "title": "Webhook Response Time",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(n8n_webhook_response_time_seconds_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(n8n_webhook_response_time_seconds_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s"}
        ]
      },
      {
        "id": 7,
        "title": "Top Failed Workflows",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
        "targets": [
          {
            "expr": "topk(10, sum by(workflow_name) (rate(n8n_workflow_executions_failed_total[1h])))",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {"Time": true},
              "indexByName": {},
              "renameByName": {
                "workflow_name": "Workflow",
                "Value": "Failures/hour"
              }
            }
          }
        ]
      },
      {
        "id": 8,
        "title": "Workflow Execution Timeline",
        "type": "graph",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "expr": "sum by(workflow_name) (rate(n8n_workflow_executions_success_total[5m]))",
            "legendFormat": "{{workflow_name}}",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Executions/sec"}
        ]
      },
      {
        "id": 9,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 0, "y": 24},
        "targets": [
          {
            "expr": "(rate(n8n_workflow_executions_failed_total[5m]) / (rate(n8n_workflow_executions_success_total[5m]) + rate(n8n_workflow_executions_failed_total[5m]))) * 100",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Total Executions Today",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 8, "y": 24},
        "targets": [
          {
            "expr": "sum(increase(n8n_workflow_executions_success_total[24h])) + sum(increase(n8n_workflow_executions_failed_total[24h]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "blue", "value": null}
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Average Execution Time",
        "type": "stat",
        "gridPos": {"h": 4, "w": 8, "x": 16, "y": 24},
        "targets": [
          {
            "expr": "rate(n8n_workflow_execution_duration_seconds_sum[5m]) / rate(n8n_workflow_execution_duration_seconds_count[5m])",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 60},
                {"color": "red", "value": 180}
              ]
            }
          }
        }
      }
    ]
  }
}

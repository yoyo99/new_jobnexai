# JobNexAI Scrapers Environment Variables
# =====================================

# Supabase Configuration (Required)
VITE_SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# LinkedIn Jobs API (Optional - fallback mode if not configured)
LINKEDIN_CLIENT_ID=your_linkedin_app_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_app_client_secret  
LINKEDIN_ACCESS_TOKEN=your_linkedin_oauth_access_token

# Indeed Partner API (Optional)
INDEED_PUBLISHER_ID=your_indeed_publisher_id
INDEED_API_KEY=your_indeed_api_key

# France Travail API (Optional)
FRANCE_TRAVAIL_CLIENT_ID=your_pole_emploi_client_id
FRANCE_TRAVAIL_CLIENT_SECRET=your_pole_emploi_client_secret

# Redis Cache Configuration (Phase 1)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# API Rate Limiting
MAX_REQUESTS_PER_MINUTE=60
RATE_LIMIT_ENABLED=true

# Logging Level
LOG_LEVEL=INFO

# Monitoring & Alerts
SENTRY_DSN=your_sentry_dsn_for_error_tracking
SLACK_WEBHOOK_URL=your_slack_webhook_for_alerts

# Proxy Configuration (Advanced Scraping)
HTTP_PROXY=http://proxy:port
HTTPS_PROXY=https://proxy:port
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password

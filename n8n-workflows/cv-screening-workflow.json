        "jsCode": "// Récupère les données des deux items\nconst items = $input.all();\n\n// Item 0 : Données du CV\nconst cvData = items[0].json;\n\n// Item 1 : Données de l'offre\nconst jobData = items[1].json;\n\nconsole.log('=== DEBUG Merge CV + Job Data ===');\nconsole.log('cvData.votre_email:', cvData.votre_email);\nconsole.log('Type:', typeof cvData.votre_email);\n\n// Fusionne les données\nreturn {\n  json: {\n    cv_text: cvData.cv_text || cvData.text || '',\n    job_url: jobData.job_url || '',\n    job_data: jobData.job_text || jobData.data || '',\n    user_email: cvData.votre_email || ''\n  }\n};"

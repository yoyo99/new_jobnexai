    {
      "parameters": {
        "jsCode": "const cvText = $input.item.json.cv_text || \"\";\nconst jobData = $input.item.json.job_data || \"\";\n\n// Vérification de longueur minimale\nif (cvText.length < 200 || jobData.length < 200) {\n  return {\n    json: {\n      validation_status: \"input_error\",\n      error_message: \"CV ou offre trop court(e) (< 200 caractères)\",\n      cv_text: cvText,\n      job_data: jobData\n    }\n  };\n}\n\nconst defaultAnalysis = {\n  matching_score: 0,\n  strengths: ['Analyse en cours...'],\n  weaknesses: ['Analyse en cours...'],\n  skills_match: { matched: [], missing: [] },\n  experience_match: { level: 'unknown', years: 0, relevant: false },\n  recommendation: 'Analyse non disponible',\n  key_insights: [],\n  interview_questions: []\n};\n\ntry {\n  let aiResponse = $input.item.json.ai_analysis;\n  \n  if (typeof aiResponse === 'string') {\n    aiResponse = aiResponse\n      .replace(/^```json\\s*/gi, '')\n      .replace(/^```\\s*/gi, '')\n      .replace(/\\s*```$/gi, '')\n      .replace(/```/g, '')\n      .trim();\n    \n    aiResponse = aiResponse.replace(/\\\\n/g, '').replace(/\\\\/g, '');\n    \n    aiResponse = JSON.parse(aiResponse);\n  }\n  \n  const requiredFields = ['matching_score', 'strengths', 'weaknesses'];\n  const missingFields = requiredFields.filter(f => !aiResponse.hasOwnProperty(f));\n  \n  if (missingFields.length > 0) {\n    console.log('⚠️ Champs manquants:', missingFields.join(', '));\n    throw new Error('Champs manquants: ' + missingFields.join(', '));\n  }\n  \n  if (aiResponse.matching_score === 'N/A' || aiResponse.matching_score === null) {\n    aiResponse.matching_score = 0;\n  }\n  if (aiResponse.matching_score > 100) aiResponse.matching_score = 100;\n  if (aiResponse.matching_score < 0) aiResponse.matching_score = 0;\n  \n  const jobUrl = $input.item.json.job_url || '';\n  const userEmail = $input.item.json.user_email || '';\n  \n  return {\n    json: {\n      ...aiResponse,\n      cv_text: cvText.substring(0, 1000),\n      job_url: jobUrl,\n      user_email: userEmail,\n      analyzed_at: new Date().toISOString(),\n      validation_status: 'success',\n      analysis_type: 'cv_screening'\n    }\n  };\n  \n} catch (error) {\n  console.log('❌ Erreur validation JSON:', error.message);\n  console.log('📄 Réponse brute:', $input.item.json.ai_analysis);\n  \n  const jobUrl = $input.item.json.job_url || '';\n  const userEmail = $input.item.json.user_email || '';\n  \n  return {\n    json: {\n      ...defaultAnalysis,\n      cv_text: cvText.substring(0, 1000),\n      job_url: jobUrl,\n      user_email: userEmail,\n      analyzed_at: new Date().toISOString(),\n      validation_status: 'fallback',\n      validation_error: error.message,\n      analysis_type: 'cv_screening'\n    }\n  };\n}"
      },

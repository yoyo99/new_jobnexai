    {
      "parameters": {
        "jsCode": "const inputData = $input.all()[0].json;\n\nconst payload = {\n  model: \"gpt-4o\",\n  messages: [\n    {\n      role: \"system\",\n      content: `Tu es un expert RH spécialisé en analyse de CV.\n\nIMPORTANT : Retourne UNIQUEMENT un objet JSON valide avec cette structure EXACTE (sans backticks markdown) :\n\n{\n  \"candidate_name\": \"Prénom NOM du candidat extrait du CV\",\n  \"matching_score\": 85,\n  \"strengths\": [\"Force 1\", \"Force 2\", \"Force 3\"],\n  \"weaknesses\": [\"Faiblesse 1\", \"Faiblesse 2\"],\n  \"recommendation\": \"Recommandation détaillée\",\n  \"key_insights\": [\"Insight 1\", \"Insight 2\"],\n  \"interview_questions\": [\"Question 1\", \"Question 2\"]\n}\n\nNe retourne RIEN d'autre que ce JSON pur.`\n    },\n    {\n      role: \"user\",\n      content: `Analyse ce CV par rapport à l'offre d'emploi :\n\nCV DU CANDIDAT :\n${inputData.cv_text ? inputData.cv_text.substring(0, 4000) : 'CV non disponible'}\n\nOFFRE D'EMPLOI :\n${inputData.job_url}\n\nDescription de l'offre (HTML brut) :\n${typeof inputData.job_data === 'string' ? inputData.job_data.substring(0, 2000) : JSON.stringify(inputData.job_data).substring(0, 2000)}\n\nRetourne ton analyse au format JSON pur (sans markdown).`\n    }\n  ],\n  temperature: 0.3,\n  max_tokens: 1500\n};\n\nreturn [{\n  json: {\n    mammouthPayload: payload,\n    debugInfo: {\n      timestamp: new Date().toISOString(),\n      cv_length: inputData.cv_text?.length || 0,\n      job_url: inputData.job_url\n    }\n  }\n}];"
      },

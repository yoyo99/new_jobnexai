        "jsCode": "const analysis = $input.item.json;\n\n// Récupérer l'email depuis le formulaire\nconst userEmail = analysis.votre_email || analysis.user_email || '';\n\nconsole.log('=== DEBUG Function - JSON Validator ===');\nconsole.log('votre_email:', analysis.votre_email);\nconsole.log('user_email:', analysis.user_email);\nconsole.log('userEmail final:', userEmail);\n\nconst cvText = analysis.cv_text || '';\nconst jobData = analysis.job_data || '';\n\nif (cvText.length < 200 || jobData.length < 200) {\n  return { json: { \n    validation_status: \"input_error\", \n    error_message: `CV ou offre trop court(e) (< 200 caractères)`, \n    cv_text: cvText, \n    job_data: jobData, \n    user_language: analysis.user_language,\n    user_email: userEmail\n  }};\n}\n\nconst finalAnalysis = {\n  ...analysis,\n  cv_text: cvText,\n  job_data: jobData,\n  user_email: userEmail,  // ← Email mappé correctement\n  user_language: analysis.user_language,\n  analyzed_at: new Date().toISOString(),\n  validation_status: \"success\",\n  analysis_type: \"cv_screening\"\n};\n\nconsole.log('=== Final Analysis ===');\nconsole.log('user_email dans finalAnalysis:', finalAnalysis.user_email);\n\nreturn { json: finalAnalysis };"

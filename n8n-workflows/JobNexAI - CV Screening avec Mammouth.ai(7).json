        "jsCode": "// Récupère le HTML brut du nœud précédent\nconst html = $input.item.json.data;\n\nfunction stripHtml(htmlString) {\n  if (!htmlString) return '';\n  let cleaned = htmlString.replace(/<script[^>]*>([\\S\\s]*?)<\\/script>/gmi, '');\n  cleaned = cleaned.replace(/<style[^>]*>([\\S\\s]*?)<\\/style>/gmi, '');\n  cleaned = cleaned.replace(/<!--[\\s\\S]*?-->/g, '');\n  cleaned = cleaned.replace(/<[^>]+>/g, ' ').replace(/&nbsp;/g, ' ');\n  cleaned = cleaned.replace(/\\s\\s+/g, ' ').trim();\n  return cleaned;\n}\n\nconst jobText = stripHtml(html);\nconsole.log(`Longueur du texte de l'offre : ${jobText.length}`);\n\nreturn { json: { job_url: $input.item.json.job_url, job_data: jobText, data: jobText } };"

        "jsCode": "const originalData = $node[\"Prepare Mammouth Request\"].json;\nconst aiResponse = $input.item.json.choices[0]?.message?.content || '';\nlet parsedAnalysis = {};\ntry {\n  const cleaned = aiResponse.replace(/```json/g, '').replace(/```/g, '').trim();\n  parsedAnalysis = JSON.parse(cleaned);\n} catch (e) {\n  parsedAnalysis = { error: \"Invalid JSON from AI\" };\n}\nconst mergedData = { ...originalData, ...parsedAnalysis };\nreturn { json: mergedData };"

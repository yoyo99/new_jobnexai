      "parameters": {
        "jsCode": "const merged = ($input.all()?.[0]?.json) ?? {};\nconst toStr = (v) => (typeof v === 'string' ? v : (v == null ? '' : String(v)));\nconst language = toStr(merged.language ?? 'fr');\nconst cvText   = toStr(merged.text ?? merged.cv_text).slice(0, 120000);\nconst jobText  = toStr(merged.job_description ?? merged.job_description_text ?? merged.job_data).slice(0, 120000);\n\nconst systemPrompt = language === 'fr'\n  ? \"Tu es un expert RH, spécialisé en analyse de CV et en rédaction de lettres de motivation.\"\n  : \"You are an HR expert, specialized in resume analysis and cover letter writing.\";\n\nconst userPrompt = language === 'fr'\n  ? `Analyse le CV et rédige une lettre de motivation brève et ciblée.\\n\\n[CV]\\n${cvText}\\n\\n[OFFRE]\\n${jobText}`\n  : `Analyze the resume and draft a concise, targeted cover letter.\\n\\n[RESUME]\\n${cvText}\\n\\n[JOB]\\n${jobText}`;\n\nreturn [{\n  json: {\n    ...merged,\n    language,\n    cv_text: cvText,\n    job_description: jobText,\n    payload: {\n      model: \"gpt-4.1\",\n      temperature: 0.2,\n      messages: [\n        { role: \"system\", content: systemPrompt },\n        { role: \"user\",   content: userPrompt }\n      ]\n    },\n    has_cv_text: cvText.length > 0,\n    has_job_text: jobText.length > 0\n  }\n}];"
      },

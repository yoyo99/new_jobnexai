    {
      "parameters": {
        "jsCode": "const puppeteer = require('puppeteer');\nconst jobUrl = $input.item.json.url_de_l_offre_d_emploi;\nasync function scrapeWithPuppeteer(url) {\n  let browser = null;\n  try {\n    browser = await puppeteer.launch({ headless: true, args: ['--no-sandbox', '--disable-setuid-sandbox'] });\n    const page = await browser.newPage();\n    await page.setUserAgent('Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36');\n    await page.goto(url, { waitUntil: 'networkidle2', timeout: 30000 });\n    await page.waitForSelector('main', { timeout: 10000 });\n    const content = await page.content();\n    return content;\n  } catch (error) {\n    console.error(`Erreur de scraping avec Puppeteer pour l'URL : ${url}`, error.message);\n    return \"\";\n  } finally {\n    if (browser) { await browser.close(); }\n  }\n}\nconst htmlContent = await scrapeWithPuppeteer(jobUrl);\nfunction stripHtml(htmlString) { if (!htmlString) return ''; let cleaned = htmlString.replace(/<script[^>]*>([\\S\\s]*?)<\\/script>/gmi, ''); cleaned = cleaned.replace(/<style[^>]*>([\\S\\s]*?)<\\/style>/gmi, ''); cleaned = cleaned.replace(/<!--[\\s\\S]*?-->/g, ''); cleaned = cleaned.replace(/<[^>]+>/g, ' ').replace(/&nbsp;/g, ' '); cleaned = cleaned.replace(/\\s\\s+/g, ' ').trim(); return cleaned; }\nconst jobText = stripHtml(htmlContent);\nconsole.log(`Scraping terminé. Longueur du texte de l'offre : ${jobText.length}`);\nreturn { json: { job_url: jobUrl, data: jobText } };"
      },

{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "module": "esnext",
    "target": "ES6",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "types": [
      "jest",
      "@testing-library/jest-dom",
      "node"
    ]
  },
  "include": [
    "src/**/*",
    "components/**/*",
    "lib/**/*",
    "tests/**/*",
    "App.tsx",
    "main.tsx",
    "./*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase/functions/**/*",
    "JobNexAI-WindSurf/**/*",
    "components/applications/**/*",
    "lib/ai.ts"
  ]
}